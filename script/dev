#!/bin/bash
# script/dev — Bang dev launcher.
#
# Defaults to the LOCAL harness backend with an isolated data profile.
# Pass --prod / --production to target the production Bang backend instead.
# All other args are forwarded to ./script/run.
set -e
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"

# Pin common agent skills to whatever skills-lock.json currently has installed.
# Skips script/run's per-launch fetch of warpdotdev/common-skills@main and the
# "skills have been updated" prompt. To adopt upstream skill updates, run
# `npx --yes skills@1.5.6 update -p -y`, commit skills-lock.json, then relaunch.
export WARP_SKIP_COMMON_SKILLS_INSTALL=1

TARGET="local"
ARGS=()
for a in "$@"; do
  case "$a" in
    --prod|--production) TARGET="prod" ;;
    *) ARGS+=("$a") ;;
  esac
done
if [ "$TARGET" = prod ]; then
  export WARP_SERVER_ROOT_URL="https://api.trybang.ai"
  # Keep RTC-served HTTP endpoints (agent-event SSE) on the harness too:
  # rtc_http_url() derives from the WS URL, which otherwise stays pointed at
  # production Warp (wss://rtc.app.warp.dev) and 401s with harness JWTs.
  export WARP_WS_SERVER_URL="wss://api.trybang.ai/graphql/v2"
  export WARP_DATA_PROFILE="production-harness"
else
  export WARP_SERVER_ROOT_URL="http://localhost:8088"
  export WARP_WS_SERVER_URL="ws://localhost:8088/graphql/v2"
  export WARP_DATA_PROFILE="local-harness"
fi
echo "[script/dev] target=$TARGET  WARP_SERVER_ROOT_URL=$WARP_SERVER_ROOT_URL  WARP_DATA_PROFILE=$WARP_DATA_PROFILE"
exec "$ROOT/script/run" "${ARGS[@]}"
