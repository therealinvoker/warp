#!/bin/bash
# script/harness — start the local Bang harness backend (Node + Express + Mongo).
#
# Ensures MongoDB is reachable (starting the brew service if needed), installs
# Node deps on first run, then launches the harness on port 8088 (the port
# `script/dev` points the client at via WARP_SERVER_ROOT_URL).
#
# Usage:
#   script/harness            # watch mode (npm run dev, auto-restart on change)
#   script/harness --start    # plain start (npm start, no file watching)
#   HARNESS_DIR=/path script/harness   # override harness checkout location
set -e

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/.. && pwd)"
HARNESS_DIR="${HARNESS_DIR:-$(cd "$ROOT/../harness-backend" 2>/dev/null && pwd || true)}"
MONGO_PORT="${MONGO_PORT:-27017}"

if [ -z "$HARNESS_DIR" ] || [ ! -f "$HARNESS_DIR/package.json" ]; then
  echo "[script/harness] harness-backend not found. Set HARNESS_DIR to its path." >&2
  echo "                 (expected a sibling of this repo: $ROOT/../harness-backend)" >&2
  exit 1
fi

# Pick npm script: watch (default) or plain start.
NPM_SCRIPT="dev"
for a in "$@"; do
  case "$a" in
    --start|--no-watch) NPM_SCRIPT="start" ;;
  esac
done

# Ensure Mongo is up. It backs identity, workspaces, and conversation storage.
if ! nc -z 127.0.0.1 "$MONGO_PORT" >/dev/null 2>&1; then
  echo "[script/harness] MongoDB not reachable on $MONGO_PORT; attempting to start it..."
  if command -v brew >/dev/null 2>&1; then
    brew services start mongodb-community || true
  fi
  for _ in $(seq 1 30); do
    nc -z 127.0.0.1 "$MONGO_PORT" >/dev/null 2>&1 && break
    sleep 1
  done
  if ! nc -z 127.0.0.1 "$MONGO_PORT" >/dev/null 2>&1; then
    echo "[script/harness] Could not reach MongoDB on $MONGO_PORT." >&2
    echo "                 Start it manually, e.g.: brew services start mongodb-community" >&2
    exit 1
  fi
fi
echo "[script/harness] MongoDB is up on $MONGO_PORT."

cd "$HARNESS_DIR"
if [ ! -d node_modules ]; then
  echo "[script/harness] Installing Node dependencies..."
  npm install
fi

echo "[script/harness] Starting harness (npm run $NPM_SCRIPT) in $HARNESS_DIR"
exec npm run "$NPM_SCRIPT"
