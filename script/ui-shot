#!/bin/bash
# script/ui-shot — screenshot a running Bang/Warp window in the BACKGROUND.
#
# Captures a specific app window by its CGWindowID (screencapture -l), so the
# window does NOT need to be frontmost and focus is NOT stolen from whatever
# you're doing (e.g. your editor stays active). This is the capture primitive
# for the local "change -> build -> screenshot -> review" UI loop; see the
# "Local UI screenshot-and-review loop" section in AGENTS.md.
#
# Requirements:
#   - The controlling app (e.g. Cursor/Terminal) needs Screen Recording
#     permission (System Settings > Privacy & Security > Screen Recording).
#     Accessibility is NOT required — we never click or send keystrokes.
#   - Swift (Xcode Command Line Tools) for the CGWindowID lookup.
#
# Usage:
#   script/ui-shot [bundle-id] [output.png]
#     bundle-id  defaults to dev.warp.WarpOssDev (the `bang-dev` dev build).
#                Use dev.warp.WarpOss for the `script/snapshot` daily driver.
#     output     defaults to /tmp/bang-ui.png
#
# Example loop step (does not steal focus):
#   open -b dev.warp.WarpOssDev "warposs://action/new_cloud_agent_conversation"
#   script/ui-shot dev.warp.WarpOssDev /tmp/bang-ui.png
set -euo pipefail

BUNDLE_ID="${1:-dev.warp.WarpOssDev}"
OUT="${2:-/tmp/bang-ui.png}"

if [ "$(uname -s)" != "Darwin" ]; then
  echo "[ui-shot] macOS only" >&2
  exit 1
fi

# Resolve the app's GUI pid from its bundle id via LaunchServices.
ASN="$(lsappinfo find "bundleid=$BUNDLE_ID" 2>/dev/null | head -1 || true)"
if [ -z "$ASN" ]; then
  echo "[ui-shot] no running app with bundle id '$BUNDLE_ID'" >&2
  exit 1
fi
PID="$(lsappinfo info -only pid "$ASN" 2>/dev/null | grep -oE '[0-9]+' | head -1 || true)"
if [ -z "$PID" ]; then
  echo "[ui-shot] could not resolve pid for '$BUNDLE_ID'" >&2
  exit 1
fi

# Find the largest normal-layer on-screen window owned by that pid and print its
# CGWindowID. Runs Swift from stdin so this stays a single self-contained file.
WID="$(/usr/bin/swift - "$PID" <<'SWIFT'
import CoreGraphics
import Foundation
let targetPID = Int32(CommandLine.arguments.count > 1 ? CommandLine.arguments[1] : "-1") ?? -1
guard let info = CGWindowListCopyWindowInfo(
    [.optionOnScreenOnly, .excludeDesktopElements], kCGNullWindowID) as? [[String: Any]]
else { exit(1) }
var bestID = 0
var bestArea = 0.0
for w in info {
    guard let pid = w[kCGWindowOwnerPID as String] as? Int32, pid == targetPID else { continue }
    guard let layer = w[kCGWindowLayer as String] as? Int, layer == 0 else { continue }
    guard let wid = w[kCGWindowNumber as String] as? Int else { continue }
    let b = w[kCGWindowBounds as String] as? [String: Any] ?? [:]
    let area = ((b["Width"] as? Double) ?? 0) * ((b["Height"] as? Double) ?? 0)
    if area > bestArea { bestArea = area; bestID = wid }
}
print(bestID)
SWIFT
)"

if [ -z "$WID" ] || [ "$WID" = "0" ]; then
  echo "[ui-shot] no on-screen window found for pid $PID (is the window minimized?)" >&2
  exit 1
fi

# -x: silent, -o: no window shadow, -l <id>: capture that window in place.
screencapture -x -o -l "$WID" "$OUT"
echo "[ui-shot] captured window $WID (pid $PID, $BUNDLE_ID) -> $OUT"
