#!/bin/bash
#
# macOS-specific implementation of `./script/run`. Runs a local version of
# Warp as a real 'app' instead of a bare executable, so macOS can treat it
# like a real signed app (custom URL schemes, user notifications, etc.).
#
# This script is invoked by `./script/run`, which handles cross-platform
# setup (install_channel_config, binary name detection, feature-to-env-var
# mapping). The following env vars are expected to be set by the caller:
#   WARP_BIN_NAME  — "warp" (internal local build) or "warp-oss"
#   WARP_CHANNEL   — "local" or "oss"
#   FEATURES       — comma-separated cargo features (already normalized)
# Must be called from the root directory of the warp repo.

set -e

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")"/../.. && pwd)"
cd "${REPO_ROOT}"

: "${WARP_BIN_NAME:?WARP_BIN_NAME must be set (invoke via ./script/run)}"
: "${WARP_CHANNEL:?WARP_CHANNEL must be set (invoke via ./script/run)}"
: "${FEATURES:?FEATURES must be set (invoke via ./script/run)}"

# Resolve Cargo's actual target directory rather than assuming ./target. This
# honors a shared CARGO_TARGET_DIR / build.target-dir (e.g. set in
# ~/.cargo/config.toml), which is where `cargo bundle` writes the .app bundle.
TARGET_DIR="$(cargo metadata --no-deps --format-version 1 | jq -r .target_directory)"
if [ -z "$TARGET_DIR" ] || [ "$TARGET_DIR" = "null" ]; then
    TARGET_DIR="${REPO_ROOT}/target"
fi

if [ "$WARP_CHANNEL" = "local" ]; then
    WARP_APP_PATH="${TARGET_DIR}/debug/bundle/osx/WarpLocal.app"
    WARP_SCHEME_NAME="warplocal"
else
    WARP_APP_PATH="${TARGET_DIR}/debug/bundle/osx/Bang.app"
    WARP_SCHEME_NAME="warposs"
fi
DONT_OPEN=false
# Launch mode. When true (the DEFAULT), the app is launched via the macOS
# application launcher ("open"/LaunchServices), which best simulates how a
# shipped Warp/Bang starts (permission prompts, URL schemes, activation). The
# process is NOT a child of this shell, so ctrl+c won't kill it (it kills the
# tail process showing the log instead). Pass --no_open_with_launchd to instead
# run the binary directly as a shell child (live stdout in this terminal, ctrl+c
# quits, and it inherits this shell's environment).
OPEN_WITH_LAUNCHD=true

# Arguments to pass directly Warp (specified after --)
# This is not supported when opening with launchd, as passing CLI arguments to
# an application doesn't make sense.
WARP_ARGS=()

# Export this variable so it can be referenced by app/build.rs later when
# running `cargo bundle`.
export FRAMEWORK_OVERRIDE="dev"

PARAMS=""
while (( "$#" )); do
  case "$1" in
    --)
      shift
      WARP_ARGS=("$@")
      break
      ;;
    --dont-open)
      DONT_OPEN=true
      shift
      ;;
    --release)
      echo "Detected release build, pointing at release bundle under ${TARGET_DIR}/release/bundle"
      if [ "$WARP_CHANNEL" = "local" ]; then
          WARP_APP_PATH="${TARGET_DIR}/release/bundle/osx/WarpLocal.app"
      else
          WARP_APP_PATH="${TARGET_DIR}/release/bundle/osx/Bang.app"
      fi
      PARAMS="$PARAMS $1"
      shift
      ;;
    --profile)
      PROFILE="$2"
      shift 2
      if [ "$WARP_CHANNEL" = "local" ]; then
          WARP_APP_PATH="${TARGET_DIR}/${PROFILE}/bundle/osx/WarpLocal.app"
      else
          WARP_APP_PATH="${TARGET_DIR}/${PROFILE}/bundle/osx/Bang.app"
      fi
      PARAMS="$PARAMS --profile $PROFILE"
      ;;
    --open_with_launchd)
      # Now the default; kept for backward compatibility.
      OPEN_WITH_LAUNCHD=true
      shift
      ;;
    --no_open_with_launchd)
      OPEN_WITH_LAUNCHD=false
      shift
      ;;
    --generate-schema)
      GENERATE_SCHEMA=true
      shift
      ;;
    *) # preserve positional arguments
      PARAMS="$PARAMS $1"
      shift
      ;;
  esac
done

# `open` (launchd) can't forward CLI args to the app; if the caller passed
# `-- <args>`, launch directly instead so the args aren't silently dropped.
if [ "$OPEN_WITH_LAUNCHD" = true ] && [ ${#WARP_ARGS[@]} -gt 0 ]; then
  echo "Note: '-- <args>' supplied; launching directly (not via launchd) so they reach the app."
  OPEN_WITH_LAUNCHD=false
fi

rm -rf "$WARP_APP_PATH"

pushd app > /dev/null
echo "Bundling app (bin: $WARP_BIN_NAME)..."
cargo bundle --bin "$WARP_BIN_NAME" --features "$FEATURES" $PARAMS
echo "Successfully bundled..."
popd > /dev/null

if [[ ",$FEATURES," =~ ",cocoa_sentry," ]]; then
  echo "Copying Sentry framework into app bundle..."
  SENTRY_FRAMEWORK="app/frameworks/dev/Sentry-Dynamic-WithARM64e.xcframework/macos-arm64_arm64e_x86_64/Sentry.framework"
  mkdir -p "$WARP_APP_PATH/Contents/Frameworks"
  cp -a "$SENTRY_FRAMEWORK" "$WARP_APP_PATH/Contents/Frameworks/"
fi
echo "Adding rpath to support mac frameworks (e.g. Sentry)"
install_name_tool -add_rpath "@executable_path/../Frameworks" "$WARP_APP_PATH/Contents/MacOS/$WARP_BIN_NAME"

export WARP_SCHEME_NAME
export WARP_PLIST_PATH="$WARP_APP_PATH/Contents/Info.plist"
./script/update_plist

# LaunchServices (`open`/launchd) does NOT inherit this shell's environment, so a
# shell-exported WARP_SERVER_ROOT_URL (which points the OSS client at a local
# harness) would be dropped — the client would fall back to its default backend,
# which rejects the harness's non-Firebase JWT with a 401 "ID token has no 'kid'".
# When launching via launchd, bake any set server overrides into the bundle's
# LSEnvironment so the app talks to the same backend as a direct run. Must run
# before codesign below so the signature covers the final plist.
if [ "$OPEN_WITH_LAUNCHD" = true ]; then
  LSENV_XML=""
  [ -n "${WARP_SERVER_ROOT_URL:-}" ] && LSENV_XML="${LSENV_XML}<key>WARP_SERVER_ROOT_URL</key><string>${WARP_SERVER_ROOT_URL}</string>"
  [ -n "${WARP_WS_SERVER_URL:-}" ] && LSENV_XML="${LSENV_XML}<key>WARP_WS_SERVER_URL</key><string>${WARP_WS_SERVER_URL}</string>"
  [ -n "${WARP_SESSION_SHARING_SERVER_URL:-}" ] && LSENV_XML="${LSENV_XML}<key>WARP_SESSION_SHARING_SERVER_URL</key><string>${WARP_SESSION_SHARING_SERVER_URL}</string>"
  if [ -n "$LSENV_XML" ]; then
    echo "Baking server overrides into LSEnvironment for launchd launch"
    plutil -insert LSEnvironment -xml "<dict>${LSENV_XML}</dict>" "$WARP_PLIST_PATH"
  fi
fi

echo "Preparing bundled resources..."
if [ "${GENERATE_SCHEMA:-false}" != "true" ]; then
  export SKIP_SETTINGS_SCHEMA=1
fi
NO_LICENSES=1 "${REPO_ROOT}/script/prepare_bundled_resources" "$WARP_APP_PATH/Contents/Resources" "$WARP_CHANNEL"

"${REPO_ROOT}/script/compile_icon" "$WARP_CHANNEL" "$WARP_APP_PATH"

if [[ ",$FEATURES," =~ ",heap_usage_tracking," ]]; then
  echo "Bundling pprof..."
  HELPERS_DIR="$WARP_APP_PATH/Contents/Helpers"
  "${REPO_ROOT}/script/prepare_bundled_pprof" "$HELPERS_DIR"
fi

if [[ ",$FEATURES," =~ ",warp_control_cli," ]]; then
  WARPCTRL_SCRIPT_PATH="$WARP_APP_PATH/Contents/Resources/bin/warpctrl-$WARP_CHANNEL"
  echo "Creating warpctrl wrapper script at $WARPCTRL_SCRIPT_PATH..."
  "${REPO_ROOT}/script/macos/create_warpctrl_wrapper" \
    "$WARPCTRL_SCRIPT_PATH" \
    "../../MacOS/$WARP_BIN_NAME"
fi

# Optionally override the app's display name and bundle id so a dev build can be
# told apart from a stable snapshot in Finder / the Dock / the app switcher, and
# doesn't collide with it in LaunchServices (which keys apps by bundle id). Set
# via WARP_APP_DISPLAY_NAME / WARP_APP_BUNDLE_ID (script/dev sets both). Must run
# before codesign so the signature covers the final plist.
DISPLAY_NAME_PLIST="$WARP_APP_PATH/Contents/Info.plist"
if [ -n "${WARP_APP_DISPLAY_NAME:-}" ]; then
  echo "Setting app display name to '$WARP_APP_DISPLAY_NAME'"
  /usr/libexec/PlistBuddy -c "Set :CFBundleName $WARP_APP_DISPLAY_NAME" "$DISPLAY_NAME_PLIST" 2>/dev/null \
    || /usr/libexec/PlistBuddy -c "Add :CFBundleName string $WARP_APP_DISPLAY_NAME" "$DISPLAY_NAME_PLIST"
  /usr/libexec/PlistBuddy -c "Set :CFBundleDisplayName $WARP_APP_DISPLAY_NAME" "$DISPLAY_NAME_PLIST" 2>/dev/null \
    || /usr/libexec/PlistBuddy -c "Add :CFBundleDisplayName string $WARP_APP_DISPLAY_NAME" "$DISPLAY_NAME_PLIST"
fi
if [ -n "${WARP_APP_BUNDLE_ID:-}" ]; then
  echo "Setting bundle identifier to '$WARP_APP_BUNDLE_ID'"
  /usr/libexec/PlistBuddy -c "Set :CFBundleIdentifier $WARP_APP_BUNDLE_ID" "$DISPLAY_NAME_PLIST" 2>/dev/null \
    || /usr/libexec/PlistBuddy -c "Add :CFBundleIdentifier string $WARP_APP_BUNDLE_ID" "$DISPLAY_NAME_PLIST"
fi
# Optionally override the app icon (e.g. script/dev points this at a black
# bang-dev.icns so the dev build is visually distinct in the Dock / switcher).
# Installed before codesign so the signature covers the new icon.
if [ -n "${WARP_APP_ICON:-}" ] && [ -f "${WARP_APP_ICON}" ]; then
  echo "Setting app icon to '$WARP_APP_ICON'"
  cp "$WARP_APP_ICON" "$WARP_APP_PATH/Contents/Resources/AppIcon.icns"
  plutil -replace CFBundleIconFile -string "AppIcon" "$DISPLAY_NAME_PLIST" 2>/dev/null \
    || plutil -insert CFBundleIconFile -string "AppIcon" "$DISPLAY_NAME_PLIST"
  # Drop any adaptive-icon reference so our .icns wins on macOS Sequoia.
  plutil -remove CFBundleIconName "$DISPLAY_NAME_PLIST" 2>/dev/null || true
fi

# When we've been given a distinct display name, rename the on-disk .app
# directory to match it. `cargo bundle` always emits "Bang.app", which shares
# its on-disk name (and Team ID) with the stable snapshot at
# ~/Applications/Bang.app. macOS attributes TCC permissions — notably the Screen
# Recording grant needed for the agent's `screencapture` — to the *responsible
# app* it resolves via LaunchServices, and two bundles both named "Bang.app"
# collapse onto a single identity. That means the dev build's capture requests
# get attributed to the already-registered snapshot "Bang" (the prompt even says
# "Bang"), the grant lands on the snapshot, and the dev build never appears as
# its own grantable entry under System Settings > Privacy & Security > Screen &
# System Audio Recording. Renaming the bundle dir gives the dev build a distinct
# on-disk identity so it registers separately and can be granted on its own.
# Must run before codesign (signature covers the bundle) and before the `open`
# / lsregister calls below (which use $WARP_APP_PATH).
if [ -n "${WARP_APP_DISPLAY_NAME:-}" ]; then
  RENAMED_APP_PATH="$(dirname "$WARP_APP_PATH")/${WARP_APP_DISPLAY_NAME}.app"
  if [ "$RENAMED_APP_PATH" != "$WARP_APP_PATH" ]; then
    echo "Renaming bundle to '${WARP_APP_DISPLAY_NAME}.app' for a distinct TCC/LaunchServices identity"
    rm -rf "$RENAMED_APP_PATH"
    mv "$WARP_APP_PATH" "$RENAMED_APP_PATH"
    WARP_APP_PATH="$RENAMED_APP_PATH"
    WARP_PLIST_PATH="$WARP_APP_PATH/Contents/Info.plist"
    DISPLAY_NAME_PLIST="$WARP_PLIST_PATH"
  fi
fi

echo "Codesigning app..."
SIGNING_CERT="$(security find-identity -p codesigning -v | grep "Apple Development" | awk '{print $2}' | head -1)"
codesign --force --deep --options runtime --sign "${SIGNING_CERT:--}" "$WARP_APP_PATH" --entitlements script/Debug-Entitlements.plist

# When we overrode the name/bundle id, refresh LaunchServices so Finder / the
# Dock / the app switcher (Cmd-Tab) pick up the new identity for this build.
if [ -n "${WARP_APP_DISPLAY_NAME:-}" ] || [ -n "${WARP_APP_BUNDLE_ID:-}" ]; then
  LSREGISTER="/System/Library/Frameworks/CoreServices.framework/Frameworks/LaunchServices.framework/Support/lsregister"
  [ -x "$LSREGISTER" ] && "$LSREGISTER" -f "$WARP_APP_PATH" 2>/dev/null || true
fi

if [ "$DONT_OPEN" = false ] ; then
    if  [ "$OPEN_WITH_LAUNCHD" = true ]; then
        echo "Launching with MacOS application launcher"
        PATH="" /usr/bin/open "$WARP_APP_PATH"
        if [ "$WARP_CHANNEL" = "local" ]; then
            LOG_FILE=~/Library/Logs/warp_local.log
        elif [ "$WARP_CHANNEL" = "oss" ]; then
            LOG_FILE=~/Library/Logs/warp-oss.log
        else
            echo "Warning: unrecognized WARP_CHANNEL '$WARP_CHANNEL', defaulting to OSS log path" >&2
            LOG_FILE=~/Library/Logs/warp-oss.log
        fi
        tail -F "$LOG_FILE"
    else
        echo "Opening app at $WARP_APP_PATH/Contents/MacOS/$WARP_BIN_NAME"
        "$WARP_APP_PATH/Contents/MacOS/$WARP_BIN_NAME" "${WARP_ARGS[@]}"
    fi
fi
